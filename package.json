{
  "name": "notion-quick-note",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "build:debug": "tsx scripts/build.ts --debug",
    "dev": "tsx scripts/build.ts --debug --watch",
    "typecheck": "tsc -b",
    "check": "npm run typecheck && npm run build && npm run check:bundle && npm run check:release && npm test && npm run test:browser",
    "check:bundle": "tsx scripts/check-bundle-size.ts",
    "check:release": "tsx scripts/check-release.ts",
    "release:package": "npm run check && tsx scripts/package-extension.ts",
    "test": "tsx --test tests/*.test.ts",
    "test:browser": "npm run build && npm run check:bundle && playwright test",
    "test:e2e": "npm run test:browser"
  },
  "dependencies": {
    "@tiptap/core": "3.28.0",
    "@tiptap/extension-blockquote": "3.28.0",
    "@tiptap/extension-link": "3.28.0",
    "@tiptap/extension-ordered-list": "3.28.0",
    "@tiptap/extension-placeholder": "3.28.0",
    "@tiptap/extension-strike": "3.28.0",
    "@tiptap/extension-task-item": "3.28.0",
    "@tiptap/extension-task-list": "3.28.0",
    "@tiptap/extension-underline": "3.28.0",
    "@tiptap/starter-kit": "3.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260719.1",
    "@playwright/test": "1.61.1",
    "@types/chrome": "0.2.2",
    "@types/node": "20.19.43",
    "esbuild": "0.28.1",
    "fake-indexeddb": "^6.2.4",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
